{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Multica AI",
  "version": "0.1.0",
  "identifier": "com.multica.ai.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Multica AI",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "allowConnectingToInsecureUrls": [
        "http://127.0.0.1:8765",
        "http://localhost:8765"
      ]
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "backend-x86_64-pc-windows-msvc.exe"
    ]
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "backend-x86_64-pc-windows-msvc",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
