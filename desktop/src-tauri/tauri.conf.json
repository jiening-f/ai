{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Multica AI",
  "version": "0.1.0",
  "identifier": "com.multica.ai.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Multica AI",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": [
      "backend-x86_64-pc-windows-gnu.exe"
    ]
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "backend-x86_64-pc-windows-gnu",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
